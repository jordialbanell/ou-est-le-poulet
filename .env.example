# Copy to .env and fill with your Supabase project values
# (Project Settings → API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Cloudinary — unsigned uploads use the cloud name + a preset named "oelp_uploads".
# The API key/secret are not used in the browser (do not ship the secret to prod).
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_API_KEY=your_api_key
VITE_CLOUDINARY_API_SECRET=your_api_secret
